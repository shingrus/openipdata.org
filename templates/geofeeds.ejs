<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <meta name="description" content="<%= description %>" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/geofeeds.js" defer></script>
</head>

<body>
  <main class="shell shell-wide" data-geofeeds-root data-api-url="<%= apiUrl %>" data-db-configured="<%= dbConfigured %>">
    <section class="hero hero-compact">
      <h1><a class="hero-home" href="/"><%= serviceName %></a></h1>
      <span class="hero-connector" aria-hidden="true"></span>
      <nav class="top-menu" aria-label="Primary">
        <a href="/">Home</a>
        <span class="top-menu-separator" aria-hidden="true">|</span>
        <a href="/api/health">API</a>
        <span class="top-menu-separator" aria-hidden="true">|</span>
        <a href="/geofeeds" aria-current="page">Geofeeds</a>
      </nav>
    </section>

    <section class="grid grid-single">
      <article class="panel panel-wide">
        <div class="panel-header">
          <div class="panel-copy">
            <h2>All Discovered Geofeeds</h2>
            <p class="panel-intro">The most complete list of all discovered geofeeds.</p>
            <p class="panel-meta-link is-hidden" data-geofeeds-dump-link><a href="<%= apiUrl %>">JSON dump</a></p>
          </div>
          <dl class="stats stats-inline">
            <div>
              <dt>Rows</dt>
              <dd data-geofeeds-count><%= dbConfigured ? "..." : "0" %></dd>
            </div>
          </dl>
        </div>

        <% if (!dbConfigured) { %>
        <p class="empty-state" data-geofeeds-state>No data</p>
        <% } else { %>
        <p class="empty-state" data-geofeeds-state>Loading geofeeds...</p>
        <div class="table-wrap is-hidden" data-geofeeds-table-wrap>
          <table class="geofeed-table">
            <thead>
              <tr>
                <th scope="col">URL</th>
                <th scope="col">Last success</th>
              </tr>
            </thead>
            <tbody data-geofeeds-body></tbody>
          </table>
        </div>
        <% } %>
      </article>
    </section>
    <%- include("partials/footer.ejs") %>
  </main>
</body>

</html>
