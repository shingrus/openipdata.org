<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <meta name="description" content="<%= description %>" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <main class="shell">
    <section class="hero">
      <h1><a class="hero-home" href="/"><%= serviceName %></a></h1>
      <span class="hero-connector" aria-hidden="true"></span>
      <nav class="top-menu" aria-label="Primary">
        <a href="/geofeeds">Geofeeds</a>
        <span class="top-menu-separator" aria-hidden="true">|</span>
        <a href="/docs">Docs</a>
      </nav>
    </section>

    <section class="grid" id="data">
        <article class="panel">
            <h2>Runtime</h2>
            <dl class="stats">
          <div>
            <dt>Uptime</dt>
            <dd><%= uptimeSeconds %>s</dd>
          </div>
          <div>
            <dt>Started</dt>
            <dd><%= startedAt %></dd>
          </div>
        </dl>
        </article>
        <article class="panel">
            <h2>Docs</h2>
            <ul class="links doc-links">
                <li><a href="/docs">/docs</a></li>
                <li><a href="/what-is-geofeed">/what-is-geofeed</a></li>
                <li><a href="/what-is-asn">/what-is-asn</a></li>
            </ul>
        </article>
        <article class="panel">
            <h2>API Endpoints</h2>
            <ul class="links">
                <li><a href="/api/health">/api/health</a></li>
                <li><a href="/api/geofeeds">/api/geofeeds</a></li>
            </ul>
        </article>


    </section>
    <%- include("partials/footer.ejs") %>
  </main>
</body>

</html>
