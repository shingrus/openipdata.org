<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= serviceName %></title>
  <meta name="description" content="OpenIPdata.org" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <main class="shell">
    <section class="hero">
      <h1><a class="hero-home" href="/"><%= serviceName %></a></h1>
      <span class="hero-connector" aria-hidden="true"></span>
      <nav class="top-menu" aria-label="Primary">
        <a href="/api/health">API</a>
        <span class="top-menu-separator" aria-hidden="true">|</span>
        <a href="#data">Geofeeds</a>
        <span class="top-menu-separator" aria-hidden="true">|</span>
        <a href="#data">ASN</a>
      </nav>
    </section>

    <section class="grid" id="data">
      <article class="panel">
        <h2>Runtime</h2>
        <dl class="stats">
          <div>
            <dt>Uptime</dt>
            <dd><%= uptimeSeconds %>s</dd>
          </div>
          <div>
            <dt>Started</dt>
            <dd><%= startedAt %></dd>
          </div>
          <div>
            <dt>Render time</dt>
            <dd><%= renderTime %></dd>
          </div>
        </dl>
      </article>

      <article class="panel">
        <h2>Endpoints</h2>
        <ul class="links">
          <li><a href="/">/</a></li>
          <li><a href="/api/health">/api/health</a></li>
        </ul>
      </article>

    </section>
  </main>
</body>

</html>
