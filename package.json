{
  "name": "openipdata-org",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Fastify SSR app for openipdata.org",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --include 'templates/**/*.ejs' src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@fastify/view": "^11.1.1",
    "ejs": "^5.0.1",
    "fastify": "^5.6.1",
    "maxmind": "^5.0.5",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.6.1",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
